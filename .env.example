# ─────────────────────────────────────────────────────────────────
#  EnterpriseCertIQ  ·  Environment Configuration Template
#
#  Copy this file to .env.local and fill in your values.
#  Never commit .env.local — it is in .gitignore.
#
#  Sections (all Azure sections are opt-in; local defaults work
#  with no Azure account):
#    1. Backend toggles       (required)
#    2. Foundry Local         (local model server)
#    3. Azure AI Foundry      (cloud model + agents)
#    4. Foundry IQ            (knowledge retrieval)
#    5. Work IQ / Graph       (work-context signals)
#    6. Fabric IQ             (semantic ontology)
#    7. Telemetry             (App Insights)
#    8. Audio                 (Azure AI Speech TTS)
#    9. Content Safety        (Azure AI Content Safety)
#   10. Key Vault             (secret store)
#   11. Reliability           (cache + fallback)
#   12. Service Principal     (Entra identity)
#   13. App settings
# ─────────────────────────────────────────────────────────────────


# ── 1. Backend toggles ────────────────────────────────────────────
# MODEL_BACKEND controls which model server is used:
#   "foundry_local"  → run models on your device via Foundry Local SDK (no Azure needed)
#   "azure_foundry"  → use an Azure AI Foundry project for inference
MODEL_BACKEND=foundry_local

# Storage is always local JSON files in ./backend/data/store/ — no Azure required.
STORAGE_BACKEND=local


# ── 2. Foundry Local (MODEL_BACKEND=foundry_local) ────────────────
# OpenAI-compatible endpoint started by the Foundry Local SDK.
FOUNDRY_LOCAL_ENDPOINT=http://localhost:5273/v1

# Model alias to load. Run `python scripts/setup_foundry.py --list` to see available models.
# Recommended: qwen2.5-7b (reliable tool-calling) or qwen2.5-14b (stronger, slower).
# Avoid phi-4 / deepseek-r1 for the default role — they don't support tool-calling.
FOUNDRY_LOCAL_MODEL_ALIAS=qwen2.5-7b

# Optional: separate model for reasoning-heavy agents (Critic, Retrospective).
# Leave empty to reuse FOUNDRY_LOCAL_MODEL_ALIAS.
# Reasoning models (phi-4-reasoning, deepseek-r1) do not support tool-calling —
# the Critic runs tool-free and uses Fabric IQ context passed in-message instead.
FOUNDRY_LOCAL_REASONING_ALIAS=


# ── 3. Azure AI Foundry (MODEL_BACKEND=azure_foundry) ─────────────
# Project endpoint — Foundry portal → your project → Settings → Project endpoint.
# Format: https://<hub-name>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_PROJECT_ENDPOINT=https://your-hub-name.services.ai.azure.com/api/projects/your-project-name

# OpenAI-compatible v1 endpoint for direct inference (most reliable path).
# Foundry portal → your project → Settings → Azure OpenAI endpoint.
# Format: https://<resource>.openai.azure.com/openai/v1
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/openai/v1

# API key — Foundry portal → your project → Settings → API keys.
# Local dev: set here. Cloud: loaded from Key Vault secret "azure-ai-api-key".
# Leave empty to use DefaultAzureCredential (managed identity / az login).
AZURE_AI_API_KEY=your-foundry-api-key-here

# API version for the inference endpoint.
AZURE_AI_API_VERSION=2024-12-01-preview

# Model deployment name — Foundry portal → your project → Deployments.
AZURE_AI_MODEL_DEPLOYMENT=your-model-deployment-name

# Optional: separate deployment for reasoning agents (Critic, Retrospective).
# Set the same value as AZURE_AI_MODEL_DEPLOYMENT to use one deployment for all.
AZURE_AI_REASONING_DEPLOYMENT=your-reasoning-deployment-name

# Set true when running in Azure with a managed identity (ignores AZURE_AI_API_KEY).
AZURE_USE_MANAGED_IDENTITY=false

# Set true to pre-register all 8 agent definitions in Foundry at startup.
# Leave false (default) when agents are already pre-registered via
# scripts/register_agents_cloud_shell.py — this avoids redundant API calls.
FOUNDRY_AUTO_REGISTER=false


# ── 4. Foundry IQ — knowledge retrieval ──────────────────────────
# "local" → TF-IDF keyword search over ./backend/data/documents/ (no Azure needed).
# Azure  → set to your Azure AI Search endpoint.
FOUNDRY_IQ_ENDPOINT=local
FOUNDRY_IQ_INDEX_NAME=cert-knowledge-base

# Dedicated Azure AI Search admin key.
# Local dev: set here. Cloud: loaded from Key Vault secret "azure-search-key" when
# AZURE_KEY_VAULT_URL is set (see section 10) — no need to set this in cloud env.
# Azure portal → your Search service → Keys → Admin key.
AZURE_SEARCH_KEY=your-azure-search-admin-key-here

# Name of the Azure AI Search connection in Foundry portal (Settings → Connections).
# When set, agents are registered with AzureAISearchTool for native server-side grounding.
# Leave empty to use the direct httpx retrieval path instead.
FOUNDRY_SEARCH_CONNECTION_NAME=

# Set true to route curator/critic/assessment agents through the Foundry Responses API
# (server-side IQ retrieval + citation injection). Falls back to BaseAgent on any error.
# Requires AZURE_AI_PROJECT_ENDPOINT and a registered knowledge base connection.
FOUNDRY_USE_RESPONSES_API=false


# ── 5. Work IQ — work-context signals ────────────────────────────
# "synthetic" → use seed data from learners.json (no Azure needed, default).
# "graph"     → read real calendar data from Microsoft Graph (Calendars.Read).
WORK_IQ_SOURCE=synthetic

# Required when WORK_IQ_SOURCE=graph.
# Azure portal → Entra ID → App registrations → your app.
GRAPH_TENANT_ID=your-entra-tenant-id
GRAPH_CLIENT_ID=your-graph-app-client-id

# Optional: paste a pre-obtained access token to skip device-code flow.
GRAPH_ACCESS_TOKEN=

# Default mailbox UPN to read when no per-learner mapping is set.
GRAPH_DEFAULT_UPN=me

# Optional JSON mapping of learner IDs to M365 mailbox UPNs.
# Example: {"L-1004": "alex@contoso.com", "L-1005": "sam@contoso.com"}
GRAPH_LEARNER_UPN_MAP=


# ── 6. Fabric IQ — semantic ontology layer ───────────────────────
# "local" → in-memory ontology from ./backend/data/synthetic/*.json (default).
# Azure  → set to your Microsoft Fabric workspace endpoint.
FABRIC_IQ_ENDPOINT=local

# Fabric workspace or lakehouse name (used in Azure mode).
FABRIC_IQ_WORKSPACE=your-fabric-workspace-name

# SKU-free path: Lakehouse SQL analytics endpoint (works on Fabric Trial — no F2 needed).
# Fabric portal → your Lakehouse → Settings → SQL analytics endpoint → Server.
FABRIC_SQL_ENDPOINT=your-lakehouse-id.datawarehouse.fabric.microsoft.com
FABRIC_SQL_DATABASE=your-lakehouse-name

# Name of the Foundry agent that has the Fabric IQ (OneLake Catalog) tool attached.
# Used for on-behalf-of calls to the Fabric IQ ontology endpoint.
FABRIC_IQ_AGENT_NAME=

# Optional: Fabric lives in a different Entra tenant than Foundry.
# When all three are set, Fabric IQ uses a ClientSecretCredential for this tenant.
# Leave all three empty to use DefaultAzureCredential (same tenant as Foundry).
FABRIC_TENANT_ID=your-fabric-entra-tenant-id
FABRIC_CLIENT_ID=your-fabric-app-client-id
FABRIC_CLIENT_SECRET=your-fabric-app-client-secret


# ── 7. Telemetry (OpenTelemetry → Azure Monitor) ─────────────────
# Set ENABLE_TELEMETRY=true to export OTel spans to Application Insights.
# This activates per-agent spans, per-request HTTP traces, and Foundry GenAI traces
# visible in Foundry portal → your project → Tracing.
# How to get the connection string:
#   Azure portal → Application Insights → your resource → Overview → Connection String
# Local dev: set here. Cloud: loaded from Key Vault secret "appinsights-connection-string".
ENABLE_TELEMETRY=false
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/


# ── 8. Audio — Azure AI Speech TTS ───────────────────────────────
# Required only for the two-host audio study briefing feature.
# Azure portal → your Speech resource → Keys and Endpoint.
# Without these, the transcript is generated but audio synthesis is skipped.
# Local dev: set SPEECH_KEY here. Cloud: loaded from Key Vault secret "speech-key".
ENABLE_AUDIO=true
SPEECH_KEY=your-azure-speech-key-here
SPEECH_REGION=eastus
AUDIO_LOCALE=en-US
AUDIO_VOICE_HOST_A=en-US-AvaNeural
AUDIO_VOICE_HOST_B=en-US-AndrewNeural


# ── 9. Content Safety (Azure AI Content Safety) ───────────────────
# When endpoint + key are set, free-text agent output is screened by the live
# Content Safety API (Hate/SelfHarm/Sexual/Violence). Falls back to regex guard
# when unconfigured.
# Azure portal → your Content Safety resource → Keys and Endpoint.
# Local dev: set AZURE_CONTENT_SAFETY_KEY here. Cloud: loaded from Key Vault secret
# "azure-content-safety-key".
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-content-safety.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=your-content-safety-key-here
# Severity threshold: 0–6 (Azure scale). Default 2 = medium.
# Results at or above this level are blocked.
AZURE_CONTENT_SAFETY_THRESHOLD=2


# ── 10. Azure Key Vault (secret store for cloud deployments) ──────
# When set, secrets are loaded from Key Vault at startup and override env vars.
# The following secrets are managed by Key Vault (vault secret name → env var):
#   azure-ai-api-key             → AZURE_AI_API_KEY
#   azure-search-key             → AZURE_SEARCH_KEY
#   azure-content-safety-key     → AZURE_CONTENT_SAFETY_KEY
#   graph-access-token           → GRAPH_ACCESS_TOKEN
#   appinsights-connection-string → APPLICATIONINSIGHTS_CONNECTION_STRING
#   speech-key                   → SPEECH_KEY
# Leave empty to use env/.env values (local dev and CI).
# Azure portal → your Key Vault → Overview → Vault URI.
AZURE_KEY_VAULT_URL=https://your-keyvault-name.vault.azure.net


# ── 11. Reliability — cache + fallback ───────────────────────────
# AGENT_FALLBACK_MODE controls what happens when the model fails:
#   "auto"   → retry 3×, then use the deterministic Python fallback (default)
#   "force"  → skip the model entirely — instant demo mode, zero credentials needed
#   "off"    → surface errors instead of falling back
AGENT_FALLBACK_MODE=auto

# SHA-256 keyed cache over (model, messages, tools, temperature).
# A cache hit skips the model call entirely — cuts cost and latency on repeated runs.
ENABLE_LLM_CACHE=true
LLM_CACHE_MAX_ENTRIES=2000


# ── 12. Service Principal (Entra identity) ────────────────────────
# Use instead of AZURE_AI_API_KEY for full Entra-based auth (recommended for cloud).
# Azure portal → Entra ID → App registrations → New registration
#   → note Client ID and Tenant ID
#   → Certificates & secrets → New client secret
#   → Foundry portal → project → Access control (IAM) → assign "Azure AI Developer" role
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-app-registration-client-secret
AZURE_TENANT_ID=your-entra-tenant-id


# ── 13. App settings ──────────────────────────────────────────────
APP_NAME=EnterpriseCertIQ
LOG_LEVEL=INFO
BACKEND_PORT=8000
OWN_MCP_PORT=8001
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MS_LEARN_MCP_URL=https://learn.microsoft.com/api/mcp
